# Copier en `values.local.env` (gitignoré) et renseigner les VRAIS secrets externes.
# Les secrets Django (SECRET_KEY, DATA_ENCRYPTION_KEY, REDIS_PASSWORD,
# DEVICE_FINGERPRINT_SECRET) sont GÉNÉRÉS automatiquement par put_parameters.ps1 —
# ne pas les mettre ici.
#
# Ce fichier est lu par put_parameters.ps1 puis poussé dans SSM (/marche-cm/prod/*).

# ── RDS (mot de passe maître défini à la création de l'instance) ──────────────
DB_PASSWORD=
DB_NAME=marchecm

# ── NotchPay (LIVE) ──────────────────────────────────────────────────────────
NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_PRIVATE_KEY=
NOTCHPAY_CHECKOUT_WEBHOOK_SECRET=
NOTCHPAY_DISBURSE_WEBHOOK_SECRET=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@marche-cm.com

# ── Domaine public (cm.digital-get.com -> A record vers 16.170.68.148) ────────
ALLOWED_HOSTS=cm.digital-get.com
BACKEND_PUBLIC_URL=https://cm.digital-get.com
