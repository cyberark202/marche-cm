<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for Flutter hot reload / debugging. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!--
      Override the main network security config in debug builds so that real
      devices connected over WiFi can reach the local dev server by LAN IP.
      The main config (cleartext blocked) is restored automatically in release.
    -->
    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true" />
</manifest>
